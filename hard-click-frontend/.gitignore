# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# unlighthouse
.unlighthouse

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.claude/
# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Sentry Config File
.env.sentry-build-plugin

# ── AI 컨텍스트 문서 (2026-07-21) ──────────────────────────────
# CLAUDE.md 체인은 커밋한다 — 팀 규칙을 AI가 자동으로 읽게 하려면 저장소에 있어야 한다.
#   커밋 대상: 루트 CLAUDE.md · src/features/{도메인}/CLAUDE.md
# .claude/ (개인 세션 설정)는 위에서 계속 제외한다.

# docs/ 는 기본 제외하고, 팀 규칙 문서만 허용한다.
# (발표 자료·BE 요청 티켓·개인 초안 등 1회성 문서가 섞여 들어오는 것 방지)
docs/*
docs/blog/
docs/notion/
!docs/CONVENTIONS.md
!docs/ARCHITECTURE.md
!docs/WORKFLOW.md
!docs/TESTING.md
!docs/DEPLOYMENT.md
!docs/WORK_LOG.md
